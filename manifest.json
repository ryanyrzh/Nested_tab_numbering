{
    "manifest_version": 2,
    "name": "Nested tab numbering",
    "version": "0.1.0",
    "permissions": ["tabs", "storage", "theme"],
    "background": { "scripts": ["background.js"] },
    "options_ui": {
      "page": "options.html",
      "open_in_tab": true
    },
    "browser_specific_settings": {
      "gecko": {
        "id": "nested-tab-numbering@ryanyrzh.com",
        "update_url": "https://raw.githubusercontent.com/ryanyrzh/Nested_tab_numbering/main/updates.json",
        "strict_min_version": "78.0",
        "data_collection_permissions": {
          "required": ["none"]
        }
      }
    }
  }